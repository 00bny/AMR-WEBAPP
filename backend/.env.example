# Comma-separated list of frontend origins allowed to call this API.
# For local dev, the Next.js default port is 3000.
ALLOWED_ORIGINS=http://localhost:3000

# How many Selenium scrape jobs may run at the same time. Each one opens a
# real headless Chrome process. Keep this at 1 on Render's free tier
# (512MB RAM) - raise it only if you upgrade to a paid plan with more RAM.
MAX_CONCURRENT_SCRAPES=1

# Where job folders are stored on disk. /tmp is fine on Render (ephemeral
# storage resets on every deploy/restart, which is what we want here).
TEMP_ROOT=/tmp/amr_jobs

# How long to keep a finished/failed job's files around before auto-deleting,
# in case the user doesn't come back to download. In seconds.
JOB_TTL_AFTER_DONE_SECONDS=1800

# Hard cap on any job's lifetime, finished or not, in case a worker crashes
# mid-job and leaves files behind. In seconds.
JOB_TTL_MAX_SECONDS=7200

# AMR site base URL - change only if PEA/MEA moves the site.
AMR_BASE_URL=https://www.amr.pea.co.th
