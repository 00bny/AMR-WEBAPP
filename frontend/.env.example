# URL of the FastAPI backend.
# Local dev (default below): run the backend locally on port 8000.
# Production: change this to your Render URL, e.g. https://your-backend.onrender.com
# (set via Vercel's dashboard env var when you deploy - see README.md)

NEXT_PUBLIC_API_BASE_URL=https://amr-webapp.onrender.com
